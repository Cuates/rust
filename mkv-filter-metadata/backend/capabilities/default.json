{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:allow-open",
    "shell:allow-execute",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-set-theme"
  ],
  "scopes": {
    "shell": [
      {
        "sidecar": "ffmpeg"
      },
      {
        "sidecar": "ffprobe"
      },
      {
        "sidecar": "mkvmerge"
      }
    ]
  }
}