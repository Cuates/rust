{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:allow-execute",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-set-theme",
    "opener:allow-open-path",
    "notification:default",
    "store:default",
    "core:window:allow-show"
  ],
  "scopes": {
    "opener": [
      {
        "//": "Wildcard is required: processed_files/ lives under whatever directory the user adds to the queue, which can be anywhere.",
        "path": "**"
      }
    ],
    "shell": [
      {
        "sidecar": "ffmpeg"
      },
      {
        "sidecar": "ffprobe"
      },
      {
        "sidecar": "mkvmerge"
      }
    ]
  }
}