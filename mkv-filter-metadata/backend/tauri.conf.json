{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mkv-filter-metadata-rust",
  "version": "0.1.0",
  "identifier": "com.cuates.mkv-filter-metadata-rust",
  "build": {
    "beforeDevCommand": "pnpm -F frontend dev",
    "beforeBuildCommand": "pnpm -F frontend build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/build"
  },
  "app": {
    "windows": [
      {
        "title": "MKV Filter Metadata",
        "dragDropEnabled": true,
        "width": 850,
        "height": 900,
        "resizable": true,
        "minWidth": 720,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://releases.myapp.com/{{target}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": "YOUR_UPDATER_PUBLIC_KEY_HERE"
    }
  },
  "bundle": {
    "externalBin": [
      "sidecars/ffmpeg",
      "sidecars/ffprobe",
      "sidecars/mkvmerge"
    ],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}