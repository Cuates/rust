{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mkv-subtitle-extractor-converter-rust",
  "version": "0.1.0",
  "identifier": "com.cuates.mkv-subtitle-extractor-converter-rust",
  "build": {
    "beforeDevCommand": "pnpm --filter frontend dev",
    "beforeBuildCommand": "pnpm --filter frontend build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MKV Subtitle Extractor Converter",
        "width": 920,
        "height": 940,
        "theme": "Dark",
        "resizable": true,
        "minWidth": 920,
        "minHeight": 940
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
