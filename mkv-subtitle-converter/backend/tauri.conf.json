{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mkv-subtitle-extractor-converter-rust",
  "version": "1.9.1",
  "identifier": "com.cuates.mkv-subtitle-extractor-converter-rust",
  "build": {
    "beforeDevCommand": "pnpm --filter frontend dev",
    "beforeBuildCommand": "pnpm --filter frontend build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/build"
  },
  "app": {
    "windows": [
      {
        "title": "MKV Subtitle Extractor Converter",
        "width": 960,
        "height": 900,
        "theme": "Dark",
        "resizable": true,
        "minWidth": 800,
        "minHeight": 700,
        "visible": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "externalBin": [
      "sidecars/ffmpeg",
      "sidecars/ffprobe"
    ],
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
